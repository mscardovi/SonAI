        android:pathData="M30,54C30,40 40,30 54,30C68,30 78,40 78,54C78,68 68,78 54,78C40,78 30,68 30,54Z"
        android:fillColor="#00000000"
        android:strokeWidth="4"
        android:strokeLineCap="round">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="30"
                android:startY="30"
                android:endX="78"
                android:endY="78"
                android:type="linear">
                <item android:offset="0" android:color="#FF6200EE" />
                <item android:offset="1" android:color="#FF03DAC6" />
